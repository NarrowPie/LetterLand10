<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true"> <com.google.android.material.button.MaterialButton
    android:id="@+id/btnDeletedLogsBack"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="16dp"
    android:fontFamily="@font/kid_font"
    android:text="BACK"
    android:textColor="#FFFFFF"
    app:backgroundTint="#F44336"
    app:cornerRadius="20dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvDeletedLogsTitle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/kid_font"
        android:gravity="center_vertical|end"
        android:text="DELETED ITEMS HISTORY"
        android:textColor="#F44336"
        android:maxLines="2"
        android:includeFontPadding="false"
        app:autoSizeTextType="uniform"
        app:autoSizeMaxTextSize="28sp"
        app:autoSizeMinTextSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/btnDeletedLogsBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnDeletedLogsBack"
        app:layout_constraintTop_toTopOf="@id/btnDeletedLogsBack" />

    <ListView
        android:id="@+id/lvDeletedLogs"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:divider="#DDDDDD"
        android:dividerHeight="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnDeletedLogsBack" />

</androidx.constraintlayout.widget.ConstraintLayout>